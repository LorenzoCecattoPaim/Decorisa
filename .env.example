# ─────────────────────────────────────────────────────
# DECORISA — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores
# ─────────────────────────────────────────────────────

# App
NEXT_PUBLIC_URL=http://localhost:3000

# Database (Supabase ou Railway PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/decorisa?schema=public"

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=gere_com__openssl_rand_base64_32

# Google OAuth (opcional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Supabase (Storage para imagens)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Mercado Pago
MERCADO_PAGO_ACCESS_TOKEN=APP_USR-...
NEXT_PUBLIC_MERCADO_PAGO_PUBLIC_KEY=APP_USR-...

# E-mail (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu@email.com
SMTP_PASS=app_password
CONTACT_EMAIL=ola@decorisa.com.br

# SEO
GOOGLE_SITE_VERIFICATION=
